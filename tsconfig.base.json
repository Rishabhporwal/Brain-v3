{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "composite": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@brain/access-control": ["shared/ts/access-control/src"],
      "@brain/tenancy": ["shared/ts/tenancy/src"],
      "@brain/auth": ["shared/ts/auth/src"],
      "@brain/authz": ["shared/ts/authz/src"],
      "@brain/contracts-ts": ["shared/ts/contracts-ts/src"],
      "@brain/dto": ["shared/ts/dto/src"],
      "@brain/events": ["shared/ts/events/src"],
      "@brain/temporal": ["shared/ts/temporal/src"],
      "@brain/observability": ["shared/ts/observability/src"],
      "@brain/security": ["shared/ts/security/src"],
      "@brain/region": ["shared/ts/region/src"],
      "@brain/idempotency": ["shared/ts/idempotency/src"],
      "@brain/metric-client": ["shared/ts/metric-client/src"],
      "@brain/http": ["shared/ts/http/src"],
      "@brain/config": ["shared/ts/config/src"],
      "@brain/errors": ["shared/ts/errors/src"],
      "@brain/testing": ["shared/ts/testing/src"],
      "@brain/feature-flags": ["shared/ts/feature-flags/src"]
    }
  },
  "exclude": ["node_modules", "dist", ".next"]
}
