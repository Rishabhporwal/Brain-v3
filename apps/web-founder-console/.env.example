# Brain web-founder-console — frontend env. Copy to .env.local and fill in.

# Backend API base (the V2 BFF). Empty = same-origin Next routes. Features show empty/error states until set.
NEXT_PUBLIC_API_BASE_URL=
API_BASE_URL=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Keycloak (OIDC) auth seam ---
# A 32+ char secret for Auth.js session encryption (openssl rand -base64 32)
AUTH_SECRET=dev-only-change-me-please-32-characters
# Keycloak realm issuer, e.g. http://localhost:8080/realms/brain  (leave blank pre-backend; app still builds)
KEYCLOAK_ISSUER=
KEYCLOAK_CLIENT_ID=brain-web
KEYCLOAK_CLIENT_SECRET=

NEXT_PUBLIC_AI_NAME=Brain
