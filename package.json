{
  "name": "brain",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test:unit test:contract",
    "test:isolation": "turbo run test:isolation",
    "codegen": "turbo run codegen",
    "dev": "turbo run dev",
    "affected:build": "turbo run build --affected",
    "local:up": "make -C deployment/local up",
    "scaffold": "bash tools/scaffold_repo.sh",
    "schemas:check": "node tools/scripts/schema-registry.mjs check",
    "schemas:publish": "node tools/scripts/schema-registry.mjs publish",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.8.4",
    "turbo": "^2.1.0",
    "typescript": "^5.6.0"
  }
}
