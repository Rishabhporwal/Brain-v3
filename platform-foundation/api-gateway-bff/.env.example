# api-gateway-bff — environment. Copy to .env (or pass via compose) for local runs.

# --- Data stores ---
PG_URL=postgres://brain:brain@localhost:5440/brain
CH_URL=http://localhost:8125

# --- Auth (Keycloak) — iss check vs JWKS fetch are split so proxy/host modes both work ---
KEYCLOAK_ISSUER=http://localhost:8080/realms/brain
KEYCLOAK_JWKS_URL=http://localhost:8080/realms/brain/protocol/openid-connect/certs

# --- Shopify OAuth ---
# When BOTH id+secret are set, the wizard's "Connect" runs the real authorization-code flow; when unset
# it falls back to the dev-stub (marks connected) so the flow still builds/runs. In the Shopify app, add
# SHOPIFY_REDIRECT_URI to the "Allowed redirection URL(s)". The browser lands on the web app, which forwards
# to this BFF for the token exchange (the callback itself is unreachable by Shopify's servers — that's fine,
# the redirect is browser-driven and the token exchange is outbound from here).
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_SCOPES=read_orders,read_products
SHOPIFY_REDIRECT_URI=http://localhost:3000/api/integrations/shopify/callback
# Where the BFF sends the browser after the callback (the wizard). Also the default redirect base.
WEB_BASE=http://localhost:3000
# Override the token-exchange endpoint (tests/mocks only); defaults to https://{shop}/admin/oauth/access_token.
# SHOPIFY_TOKEN_URL=

# --- Google Ads OAuth ---
# Standard OAuth2 (access_type=offline → refresh token). Register GOOGLE_ADS_REDIRECT_URI in the Google
# Cloud console OAuth client. Developer token + login-customer-id are for Ads API calls (post-connect).
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
GOOGLE_ADS_SCOPES=https://www.googleapis.com/auth/adwords
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# GOOGLE_TOKEN_URL=   # tests/mocks only; defaults to https://oauth2.googleapis.com/token

# --- Meta (Facebook) Ads OAuth ---
# Standard OAuth2; short-lived token is upgraded to a long-lived one. Register META_REDIRECT_URI in the
# Meta app's Facebook Login settings; your account must be a test user if the app is in dev mode.
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/integrations/meta/callback
META_API_VERSION=v21.0
META_SCOPES=ads_read,ads_management
# META_TOKEN_URL=    # tests/mocks only; defaults to https://graph.facebook.com/{ver}/oauth/access_token

# --- OAuth state signing (CSRF) — falls back to AUTH_SECRET, then a dev default ---
# OAUTH_STATE_SECRET=

# --- Secret vault (dev KMS shim) — AES-256-GCM; NEVER stores token material in Postgres ---
VAULT_KEY=brain-local-dev-vault-key-change-me
VAULT_PATH=/tmp/brain-dev-vault.json

# --- Integration data backbone — Kafka/Redpanda ---
# The DATA layer: integration.connected + (future) webhook ingest events → `brain.integration.events`.
# Onboarding lifecycle does NOT go here (it stays in audit_logs). Unset → no-op. Host-run BFF: localhost:19092.
# KAFKA_BROKERS=localhost:19092
