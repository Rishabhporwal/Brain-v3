{
  "name": "@brain/access-control",
  "version": "0.0.0",
  "private": true,
  "description": "The AccessControl abstraction — the single seam services use for tenant isolation + RBAC. Composes @brain/tenancy (brand context, RLS-bound transactions, row assertions) and @brain/authz (fixed-role permissions, guards, last-owner protection). See ACCESS_CONTROL.md.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@brain/tenancy": "workspace:*",
    "@brain/authz": "workspace:*",
    "pg": "^8.13.1"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "reflect-metadata": "^0.2.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "reflect-metadata": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "reflect-metadata": "^0.2.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
