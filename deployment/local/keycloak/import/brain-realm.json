{
  "realm": "brain",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "clients": [
    {
      "clientId": "brain-web",
      "name": "Brain Founder Console",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "brain-web-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:8088/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:8088"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3000/*"
      }
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "config": {
        "clientId": "${GOOGLE_CLIENT_ID}",
        "clientSecret": "${GOOGLE_CLIENT_SECRET}",
        "defaultScope": "openid profile email",
        "syncMode": "IMPORT"
      }
    }
  ],
  "users": [
    {
      "username": "founder",
      "email": "founder@brain.dev",
      "firstName": "Brand",
      "lastName": "Founder",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "brain12345",
          "temporary": false
        }
      ],
      "realmRoles": [
        "default-roles-brain"
      ]
    }
  ]
}