{
  "realm": "brain",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "verifyEmail": true,
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyDigits": 6,
  "otpPolicyPeriod": 30,
  "smtpServer": {
    "host": "${SMTP_HOST:smtp.gmail.com}",
    "port": "${SMTP_PORT:587}",
    "from": "${SMTP_USER:}",
    "fromDisplayName": "Brain",
    "ssl": "false",
    "starttls": "true",
    "auth": "true",
    "user": "${SMTP_USER:}",
    "password": "${SMTP_PASS:}"
  },
  "clients": [
    {
      "clientId": "brain-web",
      "name": "Brain Founder Console",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "brain-web-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:8088/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:8088"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3000/*"
      }
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "config": {
        "clientId": "${GOOGLE_CLIENT_ID}",
        "clientSecret": "${GOOGLE_CLIENT_SECRET}",
        "defaultScope": "openid profile email",
        "syncMode": "IMPORT"
      }
    }
  ],
  "users": [
    {
      "id": "e17f4184-48e1-4f2b-8cea-c5aadf6d3806",
      "username": "founder",
      "email": "founder@brain.dev",
      "firstName": "Brand",
      "lastName": "Founder",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "brain12345",
          "temporary": false
        }
      ],
      "realmRoles": [
        "default-roles-brain"
      ]
    }
  ]
}