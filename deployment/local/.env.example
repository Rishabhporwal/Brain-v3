# Copy to .env and fill in. .env is gitignored; this file is committed as documentation.
#
# Google OAuth client for "Continue with Google". Keycloak brokers the sign-in via the `google`
# identity provider in keycloak/import/brain-realm.json (clientId/clientSecret read these vars).
#
# Create the client at https://console.cloud.google.com/apis/credentials (OAuth client, type "Web
# application") and add this Authorized redirect URI (single-origin / `make proxy` mode):
#   http://localhost:8088/idp/realms/brain/broker/google/endpoint
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
